@page "{restaurantId:int}"
@model DineInsights.Pages.Restaurants.DetailModel
@{
}

@if(Model.Message!=null)
{
    <div class="alert alert-info">
        @Model.Message
    </div>
}

<h2>@Model.Restaurant.Name</h2>
<div>
    Id: @Model.Restaurant.ID
</div>
<div>
    Location: @Model.Restaurant.Location
</div>
<div>
    Cuisine: @Model.Restaurant.Cuisine
</div>



<a asp-page="./List" class="btn btn-secondary">All Restaurants</a>
